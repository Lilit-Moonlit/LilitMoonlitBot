# Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# Database Configuration
# For local SQLite use: sqlite+aiosqlite:///beauty_bot.db
# For Postgres use: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=sqlite+aiosqlite:///data/beauty_bot.db

# Feature Flags
ENABLE_SOCIAL_POSTING=False

# Admin Settings
ADMIN_ID=your_telegram_id

# Meta (Facebook/Instagram) Credentials (Required only if ENABLE_SOCIAL_POSTING=True)
META_ACCESS_TOKEN=
FB_PAGE_ID_MODELS=
FB_PAGE_ID_VACANCIES=
IG_BUSINESS_ACCOUNT_ID_MODELS=
IG_BUSINESS_ACCOUNT_ID_VACANCIES=

# Channel IDs
MODEL_CHANNEL_ID=
VACANCY_CHANNEL_ID=
